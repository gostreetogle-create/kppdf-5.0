# kppdf-5.0 — environment variables template
#
# Copy this file to `.env` (which is gitignored) and fill in real values
# for local development. Build phase (next build) tolerates missing values
# thanks to the lazy Prisma proxy in src/lib/db.ts — runtime still requires
# DATABASE_URL to be set.

# =====================================
# Database
# =====================================
# PostgreSQL connection string. REQUIRED at RUNTIME (build phase tolerated via lazy proxy).
# Examples:
#   Local dev Docker (no SSL):  postgresql://postgres:postgres@localhost:5432/kppdf?sslmode=disable
#   Local native install:       postgresql://kppdf:password@localhost:5432/kppdf
#   Production (with SSL):      postgresql://user:password@host:5432/dbname
DATABASE_URL=

# =====================================
# Application
# =====================================
# Public base URL — appears in OG tags, email links, redirects.
# Defaults to http://localhost:3000 in dev (lib/env.ts fallback).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =====================================
# Authentication
# =====================================
# JWT signing secret. REQUIRED in production for token integrity.
# Generate locally with: openssl rand -base64 48
JWT_SECRET=

# =====================================
# Admin endpoints
# =====================================
# Bearer token for /api/admin/cleanup-rate-limit (rate-limit GC cron).
# Cron job must send: Authorization: Bearer $CLEANUP_SECRET
CLEANUP_SECRET=

# =====================================
# Optional
# =====================================
# Set to "1" in CI to skip interactive prompts in seed/migration scripts.
# CI=
